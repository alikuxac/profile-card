{
  "name": "profile-card",
  "version": "1.2.1",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "preview": "wrangler pages dev out",
    "deploy": "wrangler pages deploy out",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply profile-card-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply profile-card-db --local"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "next": "15.5.12",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "^15.5.12",
    "typescript": "^5",
    "wrangler": "^4.70.0"
  }
}